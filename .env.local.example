# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Prisma — use Supabase "Connection pooling" string (port 6543) for runtime
DATABASE_URL=your_supabase_postgres_url

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Vocabulary email delivery is handled by the Supabase vocab-email Edge Function.
# Set these as Supabase secrets instead:
# supabase secrets set RESEND_API_KEY=your_resend_api_key VOCAB_EMAIL_FROM="myezsat <vocab@your_verified_domain.com>" CRON_SECRET=random_cron_secret
CRON_SECRET=random_secret_for_the_next_cron_endpoint

# Next Auth (not used directly but kept for reference)
NEXTAUTH_SECRET=random_secret_string
NEXTAUTH_URL=http://localhost:3000
